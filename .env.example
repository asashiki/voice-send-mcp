# ============================================================
# voice-send-mcp configuration
# Quick start: only PUBLIC_BASE_URL is strictly required for
# remote use; with no TTS key set, the free Edge TTS is used.
# ============================================================

# Public HTTPS origin used by Claude / ChatGPT to connect to /mcp/voice
# and by the widget iframe to load /voice/*.mp3.
PUBLIC_BASE_URL=https://voice-send.example.com
PORT=3000
MCP_HTTP_PATH=/mcp/voice
ALLOWED_ORIGINS=https://voice-send.example.com

# Optional OAuth password gate for remote connectors.
# Leave empty to disable auth; set a password to enable Authorization Code auth.
MCP_AUTH_PASSWORD=

# Storage for generated audio.
VOICE_DIR=/app/data/voice
VOICE_RETENTION_HOURS=24

# Optional override when audio is served from a different origin than PUBLIC_BASE_URL.
# MCP_VOICE_AUDIO_ORIGIN=https://voice-send.example.com

# ------------------------------------------------------------
# TTS provider: edge | minimax | openai | elevenlabs | auto
# "auto" (default) picks the first configured provider in this
# order: minimax -> elevenlabs -> openai -> edge (keyless).
# Per-request text caps (auto-truncated): edge 5000, openai 4096,
# minimax 10000, elevenlabs 10000. Override with TTS_MAX_TEXT_LENGTH.
# ------------------------------------------------------------
TTS_PROVIDER=auto
# TTS_MAX_TEXT_LENGTH=

# --- Edge TTS (free, no key; some datacenter IPs are blocked with 403) ---
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
# EDGE_TTS_RATE=+0%
# EDGE_TTS_PITCH=+0Hz
# EDGE_TTS_VOLUME=+0%

# --- MiniMax T2A v2 (https://platform.minimax.io) ---
# Note: use the api.minimaxi.com endpoint with mainland-China token-plan keys.
MINIMAX_API_KEY=
MINIMAX_API_BASE_URL=https://api.minimaxi.com/v1/t2a_v2
MINIMAX_MODEL=speech-2.8-hd
# System voice id (see MiniMax voice list) or your cloned voice id.
MINIMAX_VOICE_ID=female-shaonv
# MINIMAX_GROUP_ID=
MINIMAX_VOICE_SPEED=1
MINIMAX_VOICE_VOLUME=1.35
MINIMAX_VOICE_PITCH=0
MINIMAX_SAMPLE_RATE=32000
MINIMAX_BITRATE=128000
MINIMAX_AUDIO_FORMAT=mp3
MINIMAX_CHANNEL=1

# --- OpenAI TTS (or any OpenAI-compatible /audio/speech endpoint) ---
OPENAI_API_KEY=
OPENAI_TTS_BASE_URL=https://api.openai.com/v1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_SPEED=1

# --- ElevenLabs ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
